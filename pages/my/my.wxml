
<!--my.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card card">
    <view class="user-info">
      <image class="avatar" wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}"></image>
      <view class="user-detail">
        <view class="nickname">{{userInfo.nickName || '微信用户'}}</view>
        <view class="quota-info" wx:if="{{quotaInfo}}">
          今日剩余 <text class="quota-text">{{remaining}}</text> 次
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item card" bindtap="openHelp">
      <view class="menu-icon">❓</view>
      <view class="menu-text">使用帮助</view>
      <view class="arrow">></view>
    </view>

    <view class="menu-item card" bindtap="openConfig">
      <view class="menu-icon">⚙️</view>
      <view class="menu-text">配置说明</view>
      <view class="arrow">></view>
    </view>
  </view>

  <!-- 使用提示卡片 -->
  <view class="help-card card">
    <view class="help-title">使用提示 💡</view>
    <view class="help-item">
      <text class="help-number">1</text>
      <text class="help-desc">输入你想润色的原始文案</text>
    </view>
    <view class="help-item">
      <text class="help-number">2</text>
      <text class="help-desc">选择你喜欢的风格，点击开始润色</text>
    </view>
    <view class="help-item">
      <text class="help-number">3</text>
      <text class="help-desc">AI会生成多条文案，点击喜欢的即可复制</text>
    </view>
    <view class="help-item">
      <text class="help-number">4</text>
      <text class="help-desc">打开朋友圈，长按相机粘贴发表</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info text-center text-muted mt-20">
    版本 1.0.0 (MVP)
  </view>
</view>
