
/* 全局样式 */
page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 通用按钮样式 */
.btn-primary {
  background-color: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  border: none;
  padding: 20rpx 0;
  font-size: 32rpx;
}

.btn-primary:active {
  background-color: #4096ff;
}

.btn-default {
  background-color: #f5f5f5;
  color: #333333;
  border-radius: 8rpx;
  border: 1rpx solid #d9d9d9;
  padding: 20rpx 0;
  font-size: 32rpx;
}

.btn-default:active {
  background-color: #e8e8e8;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 文字样式 */
.text-center {
  text-align: center;
}

.text-muted {
  color: #999999;
  font-size: 28rpx;
}

.text-primary {
  color: #1677ff;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }

/* 弹性布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}
